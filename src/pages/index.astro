---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="SavvySam — Life, Beauty & Bridal">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="pill pill-gold">Podcast &bull; Beauty &bull; Bridal</span>
        <h1>Real Talk from <em>Behind the Veil</em></h1>
        <p class="hero-sub">Two former bridal stylists sharing insider secrets on weddings, beauty, and living your best life. No sugarcoating &mdash; just the advice your best friend would give you.</p>
        <div class="hero-actions">
          <a href="/podcast" class="btn btn-primary">Listen Now</a>
          <a href="/about" class="btn btn-outline">Meet Savvy &amp; Sam</a>
        </div>
        <div class="hero-platforms">
          <span class="hero-platforms-label">Available on</span>
          <div class="platform-badges">
            <a href="https://podcasts.apple.com" target="_blank" rel="noopener" class="platform-badge">Apple Podcasts</a>
            <a href="https://spotify.com" target="_blank" rel="noopener" class="platform-badge">Spotify</a>
            <a href="https://www.youtube.com/@savvysamco" target="_blank" rel="noopener" class="platform-badge">YouTube</a>
          </div>
        </div>
      </div>
      <div class="hero-image-wrap">
        <div class="hero-image-frame">
          <img src="/images/logo.png" alt="SavvySam Logo" class="hero-logo-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- BRAND PILLARS -->
  <section class="section section-alt" id="pillars">
    <div class="container">
      <div class="section-header">
        <span class="pill pill-teal">What We Do</span>
        <h2>Four Pillars of SavvySam</h2>
        <p>Everything we create is built to inform, inspire, and empower you.</p>
      </div>
      <div class="grid-4 pillars-grid">
        <div class="pillar-card">
          <div class="pillar-icon">&#127908;</div>
          <h3>The Podcast</h3>
          <p>Weekly episodes with bridal insider secrets, beauty tips, and life advice from two women who've seen it all.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">&#128717;</div>
          <h3>The Boutique</h3>
          <p>A curated shop of bridal accessories, beauty essentials, merch, and digital downloads you'll actually use.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">&#128241;</div>
          <h3>The Community</h3>
          <p>TikTok, Instagram, YouTube, Facebook &amp; X &mdash; content repurposed intelligently across every platform.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">&#9997;&#65039;</div>
          <h3>The Content Hub</h3>
          <p>SEO blog articles, YouTube tutorials, and expert guides that drive organic traffic year-round.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LATEST EPISODES -->
  <section class="section" id="episodes">
    <div class="container">
      <div class="section-header">
        <span class="pill pill-gold">New Episodes</span>
        <h2>Start Listening</h2>
        <p>Dive into our latest conversations on all things bridal, beauty, and beyond.</p>
      </div>
      <div class="grid-3 episodes-grid">
        <a href="/podcast" class="episode-card">
          <div class="ep-number">Episode 1</div>
          <h3>Who the Heck Are Savvy &amp; Sam?</h3>
          <p>Your origin story &mdash; how two bridal stylists became podcast hosts and why we have insider secrets no one else will tell you.</p>
          <span class="ep-cta">Listen &rarr;</span>
        </a>
        <a href="/podcast" class="episode-card">
          <div class="ep-number">Episode 2</div>
          <h3>Dirty Secrets of Bridal Salons</h3>
          <p>Markups, sample gown pressure, pushy consultants, and how to actually get a good deal on your dream dress.</p>
          <span class="ep-cta">Listen &rarr;</span>
        </a>
        <a href="/podcast" class="episode-card">
          <div class="ep-number">Episode 3</div>
          <h3>Your Wedding Beauty Timeline</h3>
          <p>Month-by-month prep through the morning-of schedule. The expert breakdown every bride actually needs.</p>
          <span class="ep-cta">Listen &rarr;</span>
        </a>
      </div>
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/podcast" class="btn btn-outline">View All Episodes</a>
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="section section-cream" id="about-preview">
    <div class="container">
      <div class="about-preview-grid">
        <div class="about-preview-content">
          <span class="pill pill-teal">Our Story</span>
          <h2>We've Been Behind the Veil &mdash; <em>Literally</em></h2>
          <p>Between us, we've styled thousands of brides, calmed hundreds of panicking bridesmaids, and learned every insider secret the bridal industry doesn't want you to know.</p>
          <p>Now we're sharing all of it &mdash; the beauty tips that actually work, the wedding advice that saves you money, and the real talk your maid of honor is too polite to tell you.</p>
          <div class="brand-voice-pills">
            <span class="pill pill-teal">Warm &amp; Welcoming</span>
            <span class="pill pill-teal">Confidently Honest</span>
            <span class="pill pill-gold">Playfully Expert</span>
            <span class="pill pill-gold">Inclusive</span>
            <span class="pill pill-teal">Community-First</span>
          </div>
          <a href="/about" class="btn btn-primary" style="margin-top: 1.5rem;">Our Full Story</a>
        </div>
        <div class="about-preview-visual">
          <div class="about-stat-grid">
            <div class="stat-card">
              <div class="stat-number">1000+</div>
              <div class="stat-label">Brides Styled</div>
            </div>
            <div class="stat-card gold">
              <div class="stat-number">12</div>
              <div class="stat-label">Launch Episodes</div>
            </div>
            <div class="stat-card">
              <div class="stat-number">6</div>
              <div class="stat-label">Revenue Streams</div>
            </div>
            <div class="stat-card gold">
              <div class="stat-number">5</div>
              <div class="stat-label">Social Platforms</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SHOP PREVIEW -->
  <section class="section" id="shop-preview">
    <div class="container">
      <div class="section-header">
        <span class="pill pill-gold">The Boutique</span>
        <h2>Shop Our Curated Picks</h2>
        <p>Every product is hand-selected by Savvy &amp; Sam &mdash; things we actually use, love, and recommend to our brides.</p>
      </div>
      <div class="grid-3 shop-categories">
        <div class="shop-cat-card">
          <div class="shop-cat-icon">&#128141;</div>
          <h3>Bridal Accessories</h3>
          <p>Veils, hairpins, sashes, jewelry, and garter sets curated by two stylists who know what photographs beautifully.</p>
          <a href="/shop" class="btn btn-outline" style="margin-top: auto;">Browse Collection</a>
        </div>
        <div class="shop-cat-card">
          <div class="shop-cat-icon">&#128132;</div>
          <h3>Beauty Essentials</h3>
          <p>Skincare picks, makeup favorites, and nail sets. The products that made our brides glow &mdash; and the dupes that work just as well.</p>
          <a href="/shop" class="btn btn-outline" style="margin-top: auto;">Shop Beauty</a>
        </div>
        <div class="shop-cat-card">
          <div class="shop-cat-icon">&#127873;</div>
          <h3>Getting Ready Kits</h3>
          <p>Curated bridal morning-of sets and bridesmaid gift packages. Perfect for making that getting-ready moment extra special.</p>
          <a href="/shop" class="btn btn-outline" style="margin-top: auto;">See Kits</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL / COMMUNITY CTA -->
  <section class="section social-cta-section">
    <div class="container">
      <div class="social-cta-inner">
        <h2>Join the Getting Ready Room</h2>
        <p>Follow along on your favorite platform for daily bridal tips, beauty hacks, behind-the-scenes content, and the kind of honest advice you won't find anywhere else.</p>
        <div class="social-cta-grid">
          <a href="https://www.tiktok.com/@savvysamco" target="_blank" rel="noopener" class="social-card">
            <div class="social-card-icon" style="background: #010101;">TK</div>
            <div class="social-card-name">TikTok</div>
            <div class="social-card-freq">5-7x / week</div>
          </a>
          <a href="https://www.instagram.com/savvysamco" target="_blank" rel="noopener" class="social-card">
            <div class="social-card-icon" style="background: #C13584;">IG</div>
            <div class="social-card-name">Instagram</div>
            <div class="social-card-freq">4-5x / week</div>
          </a>
          <a href="https://www.youtube.com/@savvysamco" target="_blank" rel="noopener" class="social-card">
            <div class="social-card-icon" style="background: #FF0000;">YT</div>
            <div class="social-card-name">YouTube</div>
            <div class="social-card-freq">1-2x / week</div>
          </a>
          <a href="https://www.facebook.com/savvysamco" target="_blank" rel="noopener" class="social-card">
            <div class="social-card-icon" style="background: #1877F2;">FB</div>
            <div class="social-card-name">Facebook</div>
            <div class="social-card-freq">4x / week</div>
          </a>
          <a href="https://x.com/savvysamco" target="_blank" rel="noopener" class="social-card">
            <div class="social-card-icon" style="background: #000;">X</div>
            <div class="social-card-name">X / Twitter</div>
            <div class="social-card-freq">3-5x / week</div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="section section-alt" id="newsletter">
    <div class="container">
      <div class="newsletter-inner">
        <div class="newsletter-content">
          <h2>Get the Bridal Beauty Checklist</h2>
          <p>Sign up for our newsletter and get our free printable Bridal Beauty Checklist &mdash; the month-by-month guide every bride needs.</p>
        </div>
        <form class="newsletter-form" action="#" method="post">
          <input type="email" placeholder="Your email address" required class="newsletter-input" />
          <button type="submit" class="btn btn-secondary">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--teal-pale) 0%, var(--cream) 50%, var(--gold-light) 100%);
    z-index: 0;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.1);
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: -60px;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    background: rgba(27, 107, 90, 0.08);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-content h1 {
    color: var(--dark);
  }

  .hero-content h1 em {
    color: var(--teal);
    font-style: italic;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-platforms {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .hero-platforms-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
  }

  .platform-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .platform-badge {
    font-size: 0.78rem;
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    background: var(--white);
    color: var(--dark);
    font-weight: 500;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }

  .platform-badge:hover {
    background: var(--teal);
    color: var(--white);
    border-color: var(--teal);
  }

  .hero-image-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image-frame {
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--white) 0%, var(--teal-light) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 20px 60px rgba(27, 107, 90, 0.12), 0 0 0 20px rgba(201, 168, 76, 0.08);
    animation: float 6s ease-in-out infinite;
  }

  .hero-logo-img {
    width: 85%;
    height: auto;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.08));
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* PILLARS */
  .pillar-card {
    background: var(--white);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    text-align: center;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }

  .pillar-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--gold);
  }

  .pillar-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .pillar-card h3 {
    color: var(--teal);
    margin-bottom: 0.75rem;
  }

  .pillar-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* EPISODES */
  .episode-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--border);
    border-left: 4px solid var(--teal);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    transition: all 0.3s;
    text-decoration: none;
    color: inherit;
  }

  .episode-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-left-color: var(--gold);
    color: inherit;
  }

  .ep-number {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .episode-card h3 {
    font-size: 1.15rem;
    color: var(--dark);
    margin-bottom: 0.75rem;
  }

  .episode-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .ep-cta {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--teal);
    transition: color 0.3s;
  }

  .episode-card:hover .ep-cta { color: var(--gold); }

  /* ABOUT PREVIEW */
  .about-preview-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-preview-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-preview-content h2 {
    color: var(--teal);
  }

  .about-preview-content h2 em {
    color: var(--gold);
    font-style: italic;
  }

  .about-preview-content p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .brand-voice-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .about-stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .stat-card {
    background: var(--white);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    text-align: center;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }

  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-sm);
  }

  .stat-card.gold {
    background: var(--gold-light);
    border-color: #E8D5A3;
  }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--teal);
  }

  .stat-card.gold .stat-number {
    color: var(--gold-dark);
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 0.25rem;
  }

  /* SHOP CATEGORIES */
  .shop-cat-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: all 0.3s;
  }

  .shop-cat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .shop-cat-icon {
    font-size: 2.8rem;
    margin-bottom: 1rem;
  }

  .shop-cat-card h3 {
    color: var(--teal);
    margin-bottom: 0.75rem;
  }

  .shop-cat-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  /* SOCIAL CTA */
  .social-cta-section {
    background: linear-gradient(135deg, var(--teal) 0%, var(--teal-medium) 100%);
    color: var(--white);
  }

  .social-cta-inner {
    text-align: center;
  }

  .social-cta-inner h2 {
    color: var(--white);
    margin-bottom: 1rem;
  }

  .social-cta-inner > p {
    color: rgba(255, 255, 255, 0.8);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    font-size: 1.05rem;
  }

  .social-cta-grid {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .social-card {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md);
    padding: 1.5rem 1.75rem;
    text-align: center;
    transition: all 0.3s;
    text-decoration: none;
    color: var(--white);
    min-width: 140px;
    backdrop-filter: blur(8px);
  }

  .social-card:hover {
    background: rgba(255, 255, 255, 0.18);
    transform: translateY(-4px);
    color: var(--white);
  }

  .social-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    margin: 0 auto 0.75rem;
  }

  .social-card-name {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .social-card-freq {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  /* NEWSLETTER */
  .newsletter-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .newsletter-content h2 {
    color: var(--teal);
    margin-bottom: 0.5rem;
  }

  .newsletter-content p {
    color: var(--text-muted);
    max-width: 440px;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .newsletter-input {
    padding: 0.85rem 1.25rem;
    border: 2px solid var(--border);
    border-radius: var(--radius-xl);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    width: 280px;
    transition: border-color 0.3s;
    outline: none;
  }

  .newsletter-input:focus {
    border-color: var(--teal);
  }

  /* RESPONSIVE */
  @media (max-width: 968px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-sub { margin: 0 auto; }
    .hero-actions { justify-content: center; }
    .hero-platforms { justify-content: center; }
    .hero-image-frame { width: 300px; height: 300px; }
    .about-preview-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .newsletter-inner { flex-direction: column; text-align: center; }
    .newsletter-content p { margin: 0 auto; }
    .newsletter-form { width: 100%; max-width: 480px; }
    .newsletter-input { flex: 1; width: auto; }
  }

  @media (max-width: 640px) {
    .hero { min-height: auto; padding: 3rem 0; }
    .hero-image-frame { width: 240px; height: 240px; }
    .social-cta-grid { gap: 0.75rem; }
    .social-card { min-width: 120px; padding: 1.25rem 1rem; }
    .newsletter-form { flex-direction: column; }
    .newsletter-input { width: 100%; }
  }
</style>
</BaseLayout>
