---
import BaseLayout from '../layouts/BaseLayout.astro';

const episodes = [
  { n: 1, title: "Who the Heck Are Savvy & Sam?", desc: "Your origin story — how two bridal stylists became podcast hosts and why you have insider secrets no one else will tell you.", tags: ["Origin", "Bridal"] },
  { n: 2, title: "Dirty Secrets of Bridal Salons", desc: "Markups, sample gown pressure, pushy consultants, and how to actually get a good deal.", tags: ["Bridal", "Insider"] },
  { n: 3, title: "Your Wedding Beauty Timeline — Down to the Hour", desc: "Month-by-month prep through the morning-of schedule. The expert breakdown brides need.", tags: ["Beauty", "Planning"] },
  { n: 4, title: "Bridal on a Budget — Real Numbers, Real Advice", desc: "Where to save, where to splurge, and the biggest money traps. Guest bride segment.", tags: ["Budget", "Bridal"] },
  { n: 5, title: "The Bridesmaid Problem", desc: "Dress codes, body diversity, dynamics, drama, and what both brides and bridesmaids need to hear.", tags: ["Bridal", "Style"] },
  { n: 6, title: "Skincare Secrets the Beauty Industry Hides", desc: "What actually works, drugstore dupes that beat luxury, and wedding skincare don'ts.", tags: ["Beauty", "Skincare"] },
  { n: 7, title: "Style Your Life, Not Just Your Wedding", desc: "Everyday fashion from bridal stylists who think about fit and confidence for a living.", tags: ["Fashion", "Life"] },
  { n: 8, title: "Ask Us Anything — Bridal Edition", desc: "Rapid-fire listener Q&A: dress panic, trend takes, vendor questions, and wildest appointment stories.", tags: ["Q&A", "Bridal"] },
  { n: 9, title: "Health & Wellness — The Pre-Wedding Glow", desc: "Non-diet-culture approaches: nutrition, sleep, stress, and the pressure to look 'perfectly bridal'.", tags: ["Wellness", "Life"] },
  { n: 10, title: "First Comes Love, Then Figuring Out Your Style", desc: "Couples' fashion alignment — coordinating without matching, and what wedding photos teach you.", tags: ["Style", "Life"] },
  { n: 11, title: "Behind the Business of Beauty", desc: "Entrepreneurship, salon culture, navigating the industry as women — and why they both left.", tags: ["Business", "Life"] },
  { n: 12, title: "One Year From Now — The SavvySam Company Roadmap", desc: "Transparency episode: boutique launch, live events, partnerships, and asking listeners what they want.", tags: ["Business", "Community"] },
];
---

<BaseLayout title="Podcast — The SavvySam Company" description="Listen to The SavvySam Company podcast — weekly episodes on bridal insider secrets, beauty tips, and real life advice.">

  <!-- PODCAST HERO -->
  <section class="podcast-hero">
    <div class="container">
      <div class="podcast-hero-inner">
        <span class="pill pill-gold">The Podcast</span>
        <h1>Real Conversations. <em>Real Expertise.</em></h1>
        <p class="podcast-hero-sub">Every week, Savvy &amp; Sam dive deep into the world of bridal, beauty, and living your best life. Expect honesty, laughs, and the kind of insider knowledge that changes everything.</p>
        <div class="subscribe-row">
          <span class="subscribe-label">Subscribe:</span>
          <a href="https://podcasts.apple.com" target="_blank" rel="noopener" class="btn btn-primary btn-sm-pod">Apple Podcasts</a>
          <a href="https://spotify.com" target="_blank" rel="noopener" class="btn btn-secondary btn-sm-pod">Spotify</a>
          <a href="https://www.youtube.com/@savvysamco" target="_blank" rel="noopener" class="btn btn-outline btn-sm-pod btn-outline-white">YouTube</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMAT -->
  <section class="section section-alt">
    <div class="container">
      <div class="format-grid">
        <div class="format-card">
          <div class="format-icon">&#9201;</div>
          <h3>30&ndash;50 Minutes</h3>
          <p>Long enough to go deep, short enough for your commute or getting-ready time.</p>
        </div>
        <div class="format-card">
          <div class="format-icon">&#127897;</div>
          <h3>Weekly Episodes</h3>
          <p>New episodes drop every week. Subscribe so you never miss an insider secret.</p>
        </div>
        <div class="format-card">
          <div class="format-icon">&#128172;</div>
          <h3>Listener Q&amp;A</h3>
          <p>Every episode features real questions from our audience. Your voice matters here.</p>
        </div>
        <div class="format-card">
          <div class="format-icon">&#127916;</div>
          <h3>Video on YouTube</h3>
          <p>Full video versions on YouTube so you can see the reactions, the demos, and the BTS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EPISODES LIST -->
  <section class="section" id="episodes">
    <div class="container">
      <div class="section-header">
        <span class="pill pill-teal">Season 1</span>
        <h2>All Episodes</h2>
        <p>Our first 12 episodes covering everything from bridal salon secrets to building your personal style.</p>
      </div>
      <div class="episodes-list">
        {episodes.map(ep => (
          <div class="ep-card">
            <div class="ep-card-left">
              <div class="ep-num-badge">{ep.n}</div>
            </div>
            <div class="ep-card-body">
              <div class="ep-card-tags">
                {ep.tags.map(tag => (
                  <span class="pill pill-teal">{tag}</span>
                ))}
              </div>
              <h3>{ep.title}</h3>
              <p>{ep.desc}</p>
            </div>
            <div class="ep-card-action">
              <button class="play-btn" aria-label={`Play Episode ${ep.n}`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section social-cta-section">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--white); margin-bottom: 1rem;">Never Miss an Episode</h2>
      <p style="color: rgba(255,255,255,0.8); max-width: 500px; margin: 0 auto 2rem;">Subscribe on your favorite platform and join the conversation on social media.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://podcasts.apple.com" target="_blank" rel="noopener" class="btn btn-secondary">Apple Podcasts</a>
        <a href="https://spotify.com" target="_blank" rel="noopener" class="btn" style="background: var(--white); color: var(--teal);">Spotify</a>
        <a href="https://www.youtube.com/@savvysamco" target="_blank" rel="noopener" class="btn btn-outline btn-outline-white">YouTube</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .podcast-hero {
    background: linear-gradient(135deg, var(--dark) 0%, var(--teal) 100%);
    padding: 6rem 0 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .podcast-hero::before {
    content: '';
    position: absolute;
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.06);
  }

  .podcast-hero-inner {
    position: relative;
    z-index: 1;
  }

  .podcast-hero h1 {
    color: var(--white);
    max-width: 650px;
    margin: 1rem auto;
  }

  .podcast-hero h1 em {
    color: var(--gold);
    font-style: italic;
  }

  .podcast-hero-sub {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.1rem;
    max-width: 580px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .subscribe-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .subscribe-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .btn-sm-pod {
    padding: 0.6rem 1.2rem;
    font-size: 0.82rem;
  }

  .btn-outline-white {
    border-color: rgba(255, 255, 255, 0.4);
    color: var(--white);
  }
  .btn-outline-white:hover {
    background: var(--white);
    color: var(--teal);
    border-color: var(--white);
  }

  .format-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .format-card {
    text-align: center;
    padding: 1.5rem 1rem;
  }

  .format-icon {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
  }

  .format-card h3 {
    color: var(--teal);
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .format-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .episodes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ep-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: all 0.3s;
  }

  .ep-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--gold);
    transform: translateX(4px);
  }

  .ep-num-badge {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal), var(--teal-medium));
    color: var(--white);
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ep-card-body {
    flex: 1;
  }

  .ep-card-tags {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .ep-card-tags .pill {
    font-size: 0.65rem;
    padding: 2px 8px;
  }

  .ep-card-body h3 {
    font-size: 1.05rem;
    color: var(--dark);
    margin-bottom: 0.35rem;
  }

  .ep-card-body p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .play-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--teal);
    background: transparent;
    color: var(--teal);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
    flex-shrink: 0;
  }

  .play-btn:hover {
    background: var(--teal);
    color: var(--white);
  }

  .social-cta-section {
    background: linear-gradient(135deg, var(--teal) 0%, var(--teal-medium) 100%);
  }

  @media (max-width: 768px) {
    .format-grid { grid-template-columns: repeat(2, 1fr); }
    .ep-card { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .ep-card-action { align-self: flex-end; }
  }

  @media (max-width: 480px) {
    .format-grid { grid-template-columns: 1fr; }
  }
</style>
</BaseLayout>
