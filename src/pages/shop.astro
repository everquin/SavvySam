---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { icon: "&#128141;", title: "Bridal Accessories", desc: "Veils, hairpins, sashes, jewelry, and garter sets — hand-picked by two stylists who've seen what photographs beautifully and what falls apart by cocktail hour.", count: "Coming Soon" },
  { icon: "&#128132;", title: "Beauty Essentials", desc: "Skincare picks, makeup favorites, and nail sets. Every product in this collection has been tested on real brides, with real results.", count: "Coming Soon" },
  { icon: "&#127873;", title: "Getting Ready Kits", desc: "Curated bridal morning-of sets and bridesmaid gift packages. The kind of thoughtful, beautiful bundles that make everyone feel special.", count: "Coming Soon" },
  { icon: "&#128090;", title: "Fashion Finds", desc: "Accessories, seasonal style picks, and shoes. The wardrobe pieces we'd buy ourselves — and honestly, we probably already have.", count: "Coming Soon" },
  { icon: "&#127775;", title: "SavvySam Merch", desc: "Tote bags, mugs, journals, and podcast merch. Rep the brand and show the world you're part of the SavvySam community.", count: "Coming Soon" },
  { icon: "&#128196;", title: "Digital Downloads", desc: "Wedding planning checklists, beauty prep guides, and printable timelines. High value, instant access, zero shipping.", count: "Coming Soon" },
];
---

<BaseLayout title="Shop — SavvySam" description="Shop curated bridal accessories, beauty essentials, getting ready kits, and SavvySam merch.">

  <!-- SHOP HERO -->
  <section class="shop-hero">
    <div class="container">
      <span class="pill pill-gold">The Boutique</span>
      <h1>Curated by Stylists. <em>Loved by Brides.</em></h1>
      <p>Every product in our shop has been tested, recommended, and approved by Savvy &amp; Sam. If it's here, it's because we genuinely believe in it.</p>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Shop by Category</h2>
        <p>Browse our hand-picked collections — from bridal essentials to everyday style.</p>
      </div>
      <div class="grid-3 cat-grid">
        {categories.map(cat => (
          <div class="cat-card">
            <div class="cat-icon" set:html={cat.icon}></div>
            <h3>{cat.title}</h3>
            <p>{cat.desc}</p>
            <span class="pill pill-gold">{cat.count}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY SHOP WITH US -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="pill pill-teal">Why Shop With Us</span>
        <h2>The SavvySam Difference</h2>
      </div>
      <div class="grid-4 diff-grid">
        <div class="diff-item">
          <div class="diff-icon">&#9989;</div>
          <h4>Stylist-Approved</h4>
          <p>Every product passes our professional standards</p>
        </div>
        <div class="diff-item">
          <div class="diff-icon">&#128150;</div>
          <h4>Honest Reviews</h4>
          <p>We only sell what we'd recommend to our own brides</p>
        </div>
        <div class="diff-item">
          <div class="diff-icon">&#128176;</div>
          <h4>Fair Prices</h4>
          <p>Quality finds at prices that respect your budget</p>
        </div>
        <div class="diff-item">
          <div class="diff-icon">&#128230;</div>
          <h4>Fast Shipping</h4>
          <p>Quick delivery so you're never stressing about timing</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AFFILIATE DISCLOSURE -->
  <section class="section section-cream">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--teal); margin-bottom: 1rem;">Our Shop is Launching Soon</h2>
      <p style="color: var(--text-muted); max-width: 560px; margin: 0 auto 1.5rem; font-size: 1.05rem;">We're hand-selecting every product and building a shopping experience that feels as personal as a private styling appointment. Sign up to be the first to shop.</p>
      <form class="inline-form" action="#" method="post">
        <input type="email" placeholder="Get notified at launch" required class="newsletter-input" />
        <button type="submit" class="btn btn-secondary">Notify Me</button>
      </form>
      <p style="font-size: 0.78rem; color: var(--text-muted); margin-top: 1.5rem; max-width: 500px; margin-left: auto; margin-right: auto;">Some links on our site are affiliate links. We may earn a small commission at no extra cost to you. We only recommend products we truly love and use ourselves.</p>
    </div>
  </section>

</BaseLayout>

<style>
  .shop-hero {
    background: linear-gradient(135deg, var(--gold-light) 0%, var(--cream) 50%, var(--teal-pale) 100%);
    padding: 6rem 0 4rem;
    text-align: center;
  }

  .shop-hero h1 {
    max-width: 600px;
    margin: 1rem auto 0.75rem;
  }

  .shop-hero h1 em { color: var(--gold-dark); font-style: italic; }

  .shop-hero > .container > p {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 540px;
    margin: 0 auto;
  }

  .cat-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cat-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--gold);
  }

  .cat-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .cat-card h3 {
    color: var(--teal);
    margin-bottom: 0.75rem;
  }

  .cat-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .diff-item {
    text-align: center;
    padding: 1rem;
  }

  .diff-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .diff-item h4 {
    font-family: 'DM Sans', sans-serif;
    color: var(--teal);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .diff-item p {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .inline-form {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter-input {
    padding: 0.85rem 1.25rem;
    border: 2px solid var(--border);
    border-radius: var(--radius-xl);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    flex: 1;
    transition: border-color 0.3s;
    outline: none;
  }

  .newsletter-input:focus { border-color: var(--teal); }

  @media (max-width: 640px) {
    .inline-form { flex-direction: column; }
  }
</style>
</BaseLayout>
