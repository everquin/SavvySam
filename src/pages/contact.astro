---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — SavvySam" description="Get in touch with Savvy & Sam for brand partnerships, press inquiries, or just to say hello.">

  <!-- CONTACT HERO -->
  <section class="contact-hero">
    <div class="container">
      <span class="pill pill-gold">Say Hello</span>
      <h1>Let's <em>Connect</em></h1>
      <p>Whether you're a brand looking to partner, a listener with a question, or a bride who needs advice &mdash; we'd love to hear from you.</p>
    </div>
  </section>

  <!-- CONTACT CONTENT -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- FORM -->
        <div class="contact-form-wrap">
          <h2>Send Us a Message</h2>
          <form class="contact-form" action="#" method="post">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" required placeholder="Jane Smith" />
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="jane@example.com" />
              </div>
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject" required>
                <option value="">Choose a topic...</option>
                <option value="general">General Inquiry</option>
                <option value="partnership">Brand Partnership</option>
                <option value="press">Press &amp; Media</option>
                <option value="podcast">Podcast Question / Suggestion</option>
                <option value="shop">Shop / Product Inquiry</option>
                <option value="other">Something Else</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Your Message</label>
              <textarea id="message" name="message" rows="5" required placeholder="Tell us what's on your mind..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Send Message</button>
          </form>
        </div>

        <!-- SIDEBAR -->
        <div class="contact-sidebar">
          <div class="sidebar-card">
            <h3>Brand Partnerships</h3>
            <p>Interested in sponsoring the podcast or collaborating on content? We'd love to chat about how we can work together authentically.</p>
            <a href="mailto:hello@savvysam.com" class="sidebar-link">hello@savvysam.com</a>
          </div>

          <div class="sidebar-card">
            <h3>Press &amp; Media</h3>
            <p>For press inquiries, interviews, or media kits, reach out and we'll get back to you within 48 hours.</p>
            <a href="mailto:press@savvysam.com" class="sidebar-link">press@savvysam.com</a>
          </div>

          <div class="sidebar-card">
            <h3>Follow Us</h3>
            <p>The fastest way to connect is through our social channels. DMs are always open.</p>
            <div class="sidebar-social">
              <a href="https://www.tiktok.com/@savvysam" target="_blank" rel="noopener">TikTok</a>
              <a href="https://www.instagram.com/savvysam" target="_blank" rel="noopener">Instagram</a>
              <a href="https://www.youtube.com/@savvysam" target="_blank" rel="noopener">YouTube</a>
              <a href="https://www.facebook.com/savvysam" target="_blank" rel="noopener">Facebook</a>
              <a href="https://x.com/savvysam" target="_blank" rel="noopener">X / Twitter</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-hero {
    background: linear-gradient(135deg, var(--teal) 0%, var(--teal-medium) 100%);
    padding: 6rem 0 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .contact-hero::before {
    content: '';
    position: absolute;
    top: -50px;
    left: -50px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.12);
  }

  .contact-hero h1 {
    color: var(--white);
    margin: 1rem auto 0.75rem;
  }

  .contact-hero h1 em { color: var(--gold); font-style: italic; }

  .contact-hero > .container > p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.1rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-form-wrap h2 {
    color: var(--teal);
    margin-bottom: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--dark);
    margin-bottom: 0.4rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 2px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    color: var(--text);
    transition: border-color 0.3s;
    outline: none;
    background: var(--white);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--teal);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .sidebar-card {
    background: var(--teal-pale);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .sidebar-card h3 {
    color: var(--teal);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .sidebar-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .sidebar-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--teal);
  }

  .sidebar-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sidebar-social a {
    font-size: 0.82rem;
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    background: var(--white);
    color: var(--teal);
    font-weight: 500;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }

  .sidebar-social a:hover {
    background: var(--teal);
    color: var(--white);
    border-color: var(--teal);
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
</BaseLayout>
